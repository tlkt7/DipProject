# Datasets (large files — add manually)
data/raw/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Model weights (can be large)
models/checkpoints/*
models/saved/*
!models/checkpoints/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
.env
venv/
.venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Results (generated, not tracked)
results/figures/*
results/metrics/*
!results/figures/.gitkeep
!results/metrics/.gitkeep
